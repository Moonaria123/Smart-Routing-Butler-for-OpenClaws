# 仅宿主机 → 容器端口映射（CR-DEF-02）
# 勿在此写入各服务「容器内监听端口」：Proxy 固定 8080、Dashboard 固定 3000 等由 Dockerfile / compose.environment 决定。
# 加载顺序：本文件先于项目根目录 .env，同名变量以 .env 为准。

POSTGRES_PORT=5432
REDIS_PORT=6379
REDIS_UI_PORT=8002
PROXY_PORT=8080
ROUTER_PORT=8001
DASHBOARD_PORT=3000
# Router Tester 独立 Compose（docker-compose.router-tester*.yml）宿主机映射，默认 3900
ROUTER_TESTER_PORT=3900

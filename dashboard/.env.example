# Dashboard 环境变量示例
DATABASE_URL=postgresql://user:pass@postgres:5432/routerdb
PROXY_URL=http://proxy:8080
# Dashboard 调用 Proxy LLM 超时（毫秒），默认 120000；自然语言/向导生成规则过慢时可调大
# DASHBOARD_LLM_TIMEOUT_MS=120000
BETTER_AUTH_SECRET=your-random-secret-string-here
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
# 可选：固定 INTERNAL_API_TOKEN 覆盖自动签发（见 src/lib/internal-proxy-token.ts）
# INTERNAL_API_TOKEN=
